# Bu dosyayı .env adıyla kopyalayıp kendi değerlerinizi girin:
#   cp .env.example .env
TELEGRAM_BOT_TOKEN=1234567890:AAH...
TELEGRAM_CHAT_ID=123456789
CHECK_INTERVAL_MIN=3
CHECK_INTERVAL_MAX=4
# --loop modunda her turda MIN-MAX dakika arası rastgele bir bekleme
# seçilir (küsuratlı: 3.01, 3.59 dk gibi). MAX boş bırakılırsa sabit
# MIN dakika kullanılır.

# Sadece Pi/kendi sunucunuzda çalıştırıyorsanız ve panelin (GitHub Pages)
# canlı kalmasını istiyorsanız doldurun. Boş bırakılırsa state.json/
# watchlist.json sadece yerel diskte kalır, GitHub'a push edilmez.
GITHUB_PUSH_TOKEN=
